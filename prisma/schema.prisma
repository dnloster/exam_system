generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  UNIT_COMMANDER
  UNIT_MEMBER
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_RESPONSE
  MATCHING
  FILL_IN_BLANK
  ORDERING
  DRAG_AND_DROP
  MATRIX
}

enum OptionRole {
  CHOICE
  MATCH_PROMPT
  MATCH_ANSWER
  ORDER_ITEM
  DRAG_ITEM
  DROP_ZONE
  MATRIX_ROW
  BLANK_ANSWER
}

enum OptionMediaType {
  TEXT
  IMAGE
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum QuizQuestionSlotType {
  FIXED
  RANDOM
}

enum UnitKind {
  KHOA
  PHONG_BAN
}

model User {
  id               Int                 @id @default(autoincrement())
  username         String              @unique
  passwordHash     String
  fullName         String
  role             Role                @default(UNIT_MEMBER)
  unitId           Int?
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  unit             Unit?               @relation(fields: [unitId], references: [id])
  attempts         QuizAttempt[]
  questions        Question[]          @relation("QuestionCreator")
  quizzes          Quiz[]              @relation("QuizCreator")
  quizParticipants QuizParticipant[]
  courseEnrollments CourseEnrollment[]
}

model Unit {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String   @unique
  unitKind  UnitKind @default(PHONG_BAN)
  sortOrder Int      @default(0)
  users     User[]
  quizzes   Quiz[]
}

model Course {
  id          Int                @id @default(autoincrement())
  name        String
  code        String             @unique
  description String?            @db.Text
  quizzes     Quiz[]
  enrollments CourseEnrollment[]
}

model CourseEnrollment {
  id         Int      @id @default(autoincrement())
  courseId   Int
  userId     Int
  enrolledAt DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model QuestionCategory {
  id        Int                @id @default(autoincrement())
  name      String
  quizId    Int?
  parentId  Int?
  quiz      Quiz?              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  parent    QuestionCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  QuestionCategory[] @relation("CategoryHierarchy")
  questions Question[]
  randomQuizSlots QuizQuestion[] @relation("RandomQuizSlots")

  @@unique([quizId, parentId, name])
}

model Question {
  id               Int               @id @default(autoincrement())
  name             String?
  content          String            @db.Text
  type             QuestionType      @default(MULTIPLE_CHOICE)
  category         String?
  categoryId       Int?
  points           Float             @default(1)
  generalFeedback  String?           @db.Text
  shuffleAnswers   Boolean           @default(false)
  configJson       Json?
  createdById      Int
  createdAt        DateTime          @default(now())
  createdBy        User              @relation("QuestionCreator", fields: [createdById], references: [id])
  questionCategory QuestionCategory? @relation(fields: [categoryId], references: [id])
  options          AnswerOption[]
  quizLinks        QuizQuestion[]
  answers          AttemptAnswer[]
  randomDraws      AttemptRandomDraw[] @relation("RandomDrawnQuestions")
}

model AnswerOption {
  id           Int             @id @default(autoincrement())
  questionId   Int
  text         String          @db.Text
  mediaType    OptionMediaType @default(TEXT)
  imageUrl     String?         @db.Text
  isCorrect    Boolean         @default(false)
  gradePercent Float           @default(0)
  sortOrder    Int             @default(0)
  optionRole   OptionRole      @default(CHOICE)
  groupKey     String?
  matchTarget  String?
  question     Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selections   AttemptAnswer[] @relation("SelectedOption")
}

model Quiz {
  id                 Int                 @id @default(autoincrement())
  title              String
  description        String?             @db.Text
  courseId           Int?
  unitId             Int?
  openAt             DateTime?
  closeAt            DateTime?
  timeLimitMinutes   Int?
  shuffleQuestions   Boolean             @default(false)
  questionsPerPage   Int                 @default(0)
  attemptsAllowed    Int                 @default(1)
  passingScore       Int                 @default(50)
  accessPasswordHash String?
  isPublished        Boolean             @default(false)
  createdById        Int
  createdAt          DateTime            @default(now())
  course             Course?             @relation(fields: [courseId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id])
  createdBy          User                @relation("QuizCreator", fields: [createdById], references: [id])
  questions          QuizQuestion[]
  attempts           QuizAttempt[]
  participants       QuizParticipant[]
  questionCategories QuestionCategory[]
}

model QuizParticipant {
  id       Int      @id @default(autoincrement())
  quizId   Int
  userId   Int
  addedAt  DateTime @default(now())
  quiz     Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quizId, userId])
}

model QuizQuestion {
  id                   Int                   @id @default(autoincrement())
  quizId               Int
  order                Int                   @default(0)
  slotType             QuizQuestionSlotType  @default(FIXED)
  questionId           Int?
  randomCategoryId     Int?
  includeSubcategories Boolean               @default(false)
  quiz                 Quiz                  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question             Question?             @relation(fields: [questionId], references: [id], onDelete: Cascade)
  randomCategory       QuestionCategory?     @relation("RandomQuizSlots", fields: [randomCategoryId], references: [id], onDelete: Cascade)
  randomDraws          AttemptRandomDraw[]

  @@unique([quizId, questionId])
}

model QuizAttempt {
  id          Int             @id @default(autoincrement())
  quizId      Int
  userId      Int
  startedAt   DateTime        @default(now())
  submittedAt DateTime?
  score       Float?
  status      AttemptStatus   @default(IN_PROGRESS)
  quiz        Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     AttemptAnswer[]
  randomDraws AttemptRandomDraw[]

  @@unique([quizId, userId])
}

model AttemptRandomDraw {
  id             Int          @id @default(autoincrement())
  attemptId      Int
  quizQuestionId Int
  questionId     Int
  attempt        QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  quizQuestion   QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)
  question       Question     @relation("RandomDrawnQuestions", fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, quizQuestionId])
}

model AttemptAnswer {
  id                Int           @id @default(autoincrement())
  attemptId         Int
  questionId        Int
  selectedOptionId  Int?
  selectedOptionIds Json?
  answerJson        Json?
  isCorrect         Boolean?
  scoreFraction     Float?
  attempt           QuizAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question          Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption    AnswerOption? @relation("SelectedOption", fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId])
}
